                                <Insets bottom="15.0" left="15.0" right="15.0" top="5.0" />
                            </padding>
                            <children>

                                <VBox spacing="12.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-radius: 20;">
