                                                            <padding><Insets left="10.0" /></padding>
                                                            <font><Font size="12.0" /></font>
                                                        </Label>
                                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="35.6%" textFill="#64748b">
                                                                    <font><Font size="11.0" /></font>
                                                                </Label>
                                                                <Label style="-fx-font-weight: bold;" text="671.76 EGP" textFill="WHITE">
                                                                    <font><Font size="12.0" /></font>
                                                                </Label>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnLogExpense" maxWidth="Infinity" prefHeight="50.0" style="-fx-background-color: #10b981; -fx-background-radius: 12; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-cursor: hand;" text="+ LOG EXPENSE">
                                            <effect><DropShadow color="#10b98133" radius="8" /></effect>
                                        </Button>
                                        <Button fx:id="btnHistory" maxWidth="Infinity" prefHeight="50.0" style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-border-radius: 12; -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-cursor: hand;" text="HISTORY" />
                                    </children>
                                </VBox>

                            </children>
