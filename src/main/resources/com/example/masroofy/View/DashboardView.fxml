                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="SAFE DAILY LIMIT" textFill="#94a3b8">
                                                            <font><Font name="System Bold" size="9.0" /></font>
                                                        </Label>
                                                        <Label fx:id="tvDailyLimit" text="EGP 66.67" textFill="#10b981">
                                                            <font><Font name="System Bold" size="28.0" /></font>
                                                        </Label>
                                                        <Label text="Safe to spend today" textFill="#64748b">
                                                            <font><Font size="11.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                                <Label style="-fx-font-size: 24;" text="✅" />
                                            </children>
                                        </HBox>
                                        <VBox spacing="6.0">
                                            <children>
                                                <ProgressBar maxWidth="Infinity" prefHeight="6.0" progress="0.45" style="-fx-accent: #10b981;" />
                                                <HBox>
                                                    <children>
                                                        <Label text="Spent: EGP 30.00" textFill="#94a3b8">
                                                            <font><Font size="10.0" /></font>
                                                        </Label>
                                                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Limit: EGP 66.67" textFill="#94a3b8">
                                                                    <font><Font size="10.0" /></font>
                                                                </Label>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox prefHeight="272.0" prefWidth="362.0" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-radius: 20;">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <Label text="Spending Insights" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>

                                        <StackPane prefHeight="140.0">
                                            <children>
                                                <Circle radius="55.0" stroke="#1e293b" strokeType="INSIDE" strokeWidth="10.0" style="-fx-fill: transparent;" />
                                                <Circle radius="55.0" stroke="#10b981" strokeDashArray="180, 100" strokeType="INSIDE" strokeWidth="10.0" style="-fx-fill: transparent;" />
                                                <Circle radius="55.0" stroke="#34d399" strokeDashArray="60, 400" strokeDashOffset="180" strokeType="INSIDE" strokeWidth="10.0" style="-fx-fill: transparent; -fx-opacity: 0.6;" />
                                                <VBox alignment="CENTER" spacing="1.0">
                                                    <children>
                                                        <Label text="Total" textFill="#94a3b8">
                                                            <font><Font size="10.0" /></font>
                                                        </Label>
                                                        <Label text="1,887.34" textFill="WHITE">
                                                            <font><Font name="System Bold" size="15.0" /></font>
                                                        </Label>
                                                        <Label text="EGP" textFill="#94a3b8">
                                                            <font><Font size="9.0" /></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="8.0">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 12; -fx-padding: 0 12 0 12;">
                                                    <children>
                                                        <Circle fill="#10b981" radius="4.0" />
                                                        <Label text="Transport" textFill="#e2e8f0" HBox.hgrow="ALWAYS">
                                                            <padding><Insets left="10.0" /></padding>
                                                            <font><Font size="12.0" /></font>
                                                        </Label>
                                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="48.8%" textFill="#64748b">
                                                                    <font><Font size="11.0" /></font>
                                                                </Label>
                                                                <Label style="-fx-font-weight: bold;" text="920.4 EGP" textFill="WHITE">
                                                                    <font><Font size="12.0" /></font>
                                                                </Label>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 12; -fx-padding: 0 12 0 12;">
                                                    <children>
                                                        <Circle fill="#059669" radius="4.0" />
