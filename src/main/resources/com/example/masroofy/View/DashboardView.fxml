                    </content>
                </ScrollPane>

                <HBox alignment="CENTER" prefHeight="65.0" spacing="60.0" style="-fx-background-color: #1e293b; -fx-background-radius: 25 25 0 0;">
                    <children>
                        <Label style="-fx-font-size: 20;" text="🏠" textFill="#10b981" />
                        <Label style="-fx-font-size: 20; -fx-opacity: 0.4;" text="📊" textFill="WHITE" />
                        <Label style="-fx-font-size: 20; -fx-opacity: 0.4;" text="⚙️" textFill="WHITE" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
