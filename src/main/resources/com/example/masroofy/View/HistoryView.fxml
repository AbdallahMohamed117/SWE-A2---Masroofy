<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="650.0" prefWidth="400.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Circle fill="#0ea5e9" layoutX="350.0" layoutY="80.0" radius="80.0" style="-fx-opacity: 0.12;" />
        <Circle fill="#6366f1" layoutX="50.0" layoutY="600.0" radius="90.0" style="-fx-opacity: 0.08;" />

        <VBox layoutX="25.0" layoutY="30.0" prefHeight="590.0" prefWidth="350.0" spacing="20.0"
              style="-fx-background-color: rgba(255, 255, 255, 0.03); -fx-background-radius: 30; -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-width: 1; -fx-border-radius: 30;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="25.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 10;" text="←" />
                        <Label text="History" textFill="WHITE">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <HBox spacing="10.0">
                    <children>
                        <Button style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #94a3b8; -fx-background-radius: 20; -fx-padding: 5 15;" text="Category ▾" />
                        <Button style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #94a3b8; -fx-background-radius: 20; -fx-padding: 5 15;" text="Date ▾" />
                        <Button style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 15; -fx-font-weight: bold;" text="Apply" />
                    </children>
                </HBox>

                <VBox spacing="5.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 20;">
                    <children>
                        <HBox alignment="CENTER">
                            <children>
                                <VBox HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="TOTAL EXPENSES" textFill="#94a3b8" style="-fx-font-size: 10; -fx-letter-spacing: 1;" />
                                        <Label text="EGP 430.50" textFill="#2dd4bf" style="-fx-font-weight: bold; -fx-font-size: 24;" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label text="TRANSACTIONS" textFill="#94a3b8" style="-fx-font-size: 10;" />
                                        <Label text="18" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 24;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Label text="Recent Activities" textFill="#64748b" style="-fx-font-weight: bold; -fx-font-size: 13;" />

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
                    <content>
                        <VBox spacing="12.0" style="-fx-background-color: transparent;">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 12; -fx-background-radius: 15;">
                                    <children>
                                        <Label style="-fx-background-color: rgba(45, 212, 191, 0.1); -fx-padding: 10; -fx-background-radius: 12;" text="🍔" />
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Burger King" textFill="WHITE" style="-fx-font-weight: bold;" />
                                                <Label text="Food &amp; Drinks" textFill="#64748b" style="-fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER_RIGHT" spacing="5">
                                            <children>
                                                <Label text="- EGP 120" textFill="#fb7185" style="-fx-font-weight: bold;" />
                                                <Button text="Edit" style="-fx-background-color: transparent; -fx-text-fill: #2dd4bf; -fx-font-size: 10; -fx-padding: 0; -fx-cursor: hand; -fx-underline: true;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 12; -fx-background-radius: 15;">
                                    <children>
                                        <Label style="-fx-background-color: rgba(14, 165, 233, 0.1); -fx-padding: 10; -fx-background-radius: 12;" text="🚗" />
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Uber Ride" textFill="WHITE" style="-fx-font-weight: bold;" />
                                                <Label text="Transport" textFill="#64748b" style="-fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER_RIGHT" spacing="5">
                                            <children>
                                                <Label text="- EGP 65" textFill="#fb7185" style="-fx-font-weight: bold;" />
                                                <Button text="Edit" style="-fx-background-color: transparent; -fx-text-fill: #0ea5e9; -fx-font-size: 10; -fx-padding: 0; -fx-cursor: hand; -fx-underline: true;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <Button maxWidth="Infinity" prefHeight="45.0"
                        style="-fx-background-color: #0ea5e9; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                        text="+ Add Transaction">
                    <effect>
                        <DropShadow color="#0ea5e933" radius="10" />
                    </effect>
                </Button>

            </children>
        </VBox>
    </children>
</AnchorPane>